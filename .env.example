# ─────────────────────────────────────────────────────────────
# UzTeam — Environment Variables
# Copy to .env.local (dev) or set on the server (prod)
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local dev example:  postgres://user:pass@localhost:5432/uzteam
# ahost example:      postgres://uzteam_user:password@127.0.0.1:5432/uzteam_db
DATABASE_URL=postgres://user:password@localhost:5432/uzteam

# Secret used to sign admin session JWTs (use a long random string, 32+ chars)
# Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-string

# Public base URL of the app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI API key for the AI Calculator + Chat widget.
# Optional — without it the app runs in MOCK MODE (static BR summary, DB-based pricing).
OPENAI_API_KEY=

# ── SMTP (transactional emails: "so'rov qabul qilindi" acknowledgement) ──
# Create the mailbox in cPanel → Email Accounts (e.g. no-reply@uz-team.uz).
# Optional — without it emails are skipped gracefully (lead capture still works).
SMTP_HOST=mail.uz-team.uz
SMTP_PORT=465
SMTP_USER=no-reply@uz-team.uz
SMTP_PASS=
# MAIL_FROM="UzTeam <no-reply@uz-team.uz>"   # optional, defaults to SMTP_USER
